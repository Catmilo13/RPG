def startUp():
    global name


    print("Bienvenido a RPG.")


    name = input("\n\nPor favor ingresa tu nombre: ")
    Yn = input(f"\n\nConfirmar el nombre {name}? No lo podras cambiar despues (Y/N): ")


    if Yn == 'N':
        while Yn == 'N':
            name = input("\n\nPor favor ingresa tu nombre: ")
            Yn = input(f"\n\nConfirmar el nombre {name}? No lo podras cambiar despues (Y/N): ")


    elif Yn != 'Y':
        while Yn != 'N' and Yn != 'Y':
            Yn = input("\n\nError, respuesta no valida. Ingresa de nuevo: ")


        if Yn == 'N':
            while Yn == 'N':
                name = input("\n\nPor favor ingresa tu nombre: ")
                Yn = input(f"\n\nConfirmar el nombre {name}? No lo podras cambiar despues (Y/N): ")


    mainMenu()


def mainMenu():


    print("\n------------------------------------------------------\n\nJuego RPG\n\n 1. Pelea\n 2. Estadisticas\n 3. Inventario\n 4. Tienda")


    
    while True:


        opcion = input("\n\nElige una opcion (1-4): ")
        if opcion == '1':
            fights()
            break
        elif opcion == '2':
            stats()
            break
        elif opcion == '3':
            inventory()
            break
        elif opcion == '4':
            store()
            break
        else:
            print("\n\nError. Intenta de nuevo.")
            


    return




def fights():
    global vitality, strength, speed, defense, name, xp, coins, xpToNextLevel, level, statPoints

    dodgeChance = 0

    if speed > 50:
        dodgeChance = 50
    else:
        dodgeChance = speed

    playerHp = 100 + vitality*5

    armor = 0

    enemyHp = playerHp*1.5

    maxEnemyHp = enemyHp

    enemyStrengh = strength*10

    if defense*2 > enemyStrengh-15:
        armor = enemyStrengh-15
    else:
        armor = defense*2

    enemySpeed = random.randint(speed-20, speed+5)

    win = False

    action = ''

    Eblocked = False

    Eblocking = False

    blocking = False


    while True:


        print(f"\n\nEnemy HP: {enemyHp}\n\n{name}'s HP: {playerHp}")
        
        if speed > enemySpeed:


            action = input("\n\n 1. Golpear\n 2. Blockear\n 3. Escaparse\n\n\nElige una accion (1-3): ")


            if action == '1':

                if Eblocking:
                    print(f"\n\nEl enemigo bloquea tu ataque! Haces solo {(20*strength)/2} de daño.")
                    enemyHp -= (20*strength)/2
                else:
                    print(f"\n\nGolpeas al enemigo! Haces {20*strength} de daño.")
                    enemyHp -= 20*strength


            elif action == '2':
                
                print("\n\nBloqueas el proximo ataque del enemigo!")

                blocking = True


            elif action == '3':


                defeat = True


                break

            else:


                print("\n\nError. Tu turno sera perdido.")

            if enemyHp <= 0:

                win = True

                break

            elif enemyHp < maxEnemyHp/2 and not Eblocked:

                Eblocked = True

                print("\n\nEnemigo bloquea tu proximo ataque!")

                Eblocking = True

            else:
                Eblocked = False
                if random.randint(1,100) <= dodgeChance:
                    print("\n\nLogras esquivar el ataque del enemigo!")
                else:
                    if blocking:
                        playerHp -= (enemyStrengh-armor)/2
                        print(f"\n\nEl enemigo ataca! Pero, al bloquear, solo hace {(enemyStrengh-armor)/2} de daño.")
                    else:
                        playerHp -= enemyStrengh-defense
                        print(f"\n\nEl enemigo ataca! Hace {enemyStrengh-armor} de daño.")

                    if playerHp <= 0:
                        break
        else:
            if enemyHp < maxEnemyHp/2 and not Eblocked:

                Eblocked = True

                print("\n\nEnemigo bloquea tu proximo ataque!")

                Eblocking = True

            else:
                Eblocked = False
                if random.randint(1,100) <= dodgeChance:
                    print("\n\nLogras esquivar el ataque del enemigo!")
                else:
                    if blocking:
                        playerHp -= (enemyStrengh-armor)/2
                        print(f"\n\nEl enemigo ataca! Pero, al bloquear, solo hace {(enemyStrengh-armor)/2} de daño.")
                    else:
                        playerHp -= enemyStrengh-defense
                        print(f"\n\nEl enemigo ataca! Hace {enemyStrengh-armor} de daño.")

                    if playerHp <= 0:
                        break

            action = input("\n\n 1. Golpear\n 2. Blockear\n 3. Escaparse\n\n\nElige una accion (1-3): ")


            if action == '1':

                if Eblocking:
                    print(f"\n\nEl enemigo bloquea tu ataque! Haces solo {(20*strength)/2} de daño.")
                    enemyHp -= (20*strength)/2
                else:
                    print(f"\n\nGolpeas al enemigo! Haces {20*strength} de daño.")
                    enemyHp -= 20*strength


            elif action == '2':
                
                print("\n\nBloqueas el proximo ataque del enemigo!")

                blocking = True


            elif action == '3':
                break

            else:


                print("\n\nError. Tu turno sera perdido.")

            if enemyHp <= 0:

                win = True

                break
        blocking = False
        Eblocking = False

        print("\n\n------------------------------------------------------")

    if win:
        print(f"\n\nFelicidades! Has ganado la pelea! Has ganado {50+maxEnemyHp} de XP y {20+enemyStrengh} monedas!")
        xp += 50+maxEnemyHp/2
        coins += 20+enemyStrengh
        if xp >= xpToNextLevel:
            while xp >= xpToNextLevel:
                level += 1
                statPoints += 3
                xp -= xpToNextLevel
                xpToNextLevel = int(xpToNextLevel*1.35)
                print(f"\n\nHas subido de nivel! Ahora eres nivel {level}! Tienes {statPoints} puntos de estadistica para gastar!")
    else:
        print("\n\nHas sido derrotado... Mejor suerte la proxima vez!")
    
    mainMenu()
    return


            
def stats ():
    global vitality, strength, speed, defense, name, xp, coins, xpToNextLevel, level, statPoints

    print(f"\n\n{name}'s Stats\n\nNivel: {level}\nXP: {xp}/{xpToNextLevel}\nMonedas: {coins}\nVitalidad: {vitality}\nFuerza: {strength}\nVelocidad: {speed}\nDefensa: {defense}\nPuntos de estadistica sin gastar: {statPoints}")

    Yn = input("\n\nQuieres gastar tus puntos de estadistica? (Y/N): ")

