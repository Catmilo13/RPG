def startUp():
    global name

    clear_console()

    print("Bienvenido a RPG.")


    name = input("\n\nPor favor ingresa tu nombre: ")
    Yn = input(f"\n\nConfirmar el nombre {name}? No lo podras cambiar despues (Y/N): ").upper()



