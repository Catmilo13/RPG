def stats ():
    global vitality, strength, speed, defense, name, xp, coins, xpToNextLevel, level, statPoints, perception

    clear_console()

    print("\n\n------------------------------------------------------")

    print(f"\n\n{name}'s Stats\n\nNivel: {level}\nXP: {xp}/{xpToNextLevel}\nMonedas: {coins}\nVitalidad: {vitality}\nFuerza: {strength}\nVelocidad: {speed}\nDefensa: {defense}\nPercepcion: {perception}\nPuntos de estadistica sin gastar: {statPoints}")

    Yn = input("\n\nQuieres gastar tus puntos de estadistica? (Y/N): ").upper()

    statChosen = 0
    statAmount = 0

    if Yn == 'Y' and statPoints > 0:
        while statPoints > 0:
            statChose = input("\n\nQue estadistica quieres mejorar? (1. Vitalidad, 2. Fuerza, 3. Velocidad, 4. Defensa, 5. Percepcion): ")
            try:
                statAmount = int(input("\n\nCuantos puntos quieres gastar? "))
            except ValueError:
                statAmount = 0

            if statAmount > statPoints or statAmount <= 0:
                print("\n\nError. Cantidad invalida.")
            else:
                if statChose == '1':
                    vitality += statAmount
                    statPoints -= statAmount
                elif statChose == '2':
                    strength += statAmount
                    statPoints -= statAmount
                elif statChose == '3':
                    speed += statAmount
                    statPoints -= statAmount
                elif statChose == '4':
                    defense += statAmount
                    statPoints -= statAmount
                elif statChose == '5':
                    perception += statAmount
                    statPoints -= statAmount
                else:
                    print("\n\nError. No se ha gastado ningun punto de estadistica.")

            if statPoints <= 0:
                break

            continuar = input(f"\n\nQuieres mejorar otra estadistica? Tienes {statPoints} puntos para gastar restantes (Y/N): ").upper()
            if continuar != 'Y':
                break
    elif Yn == 'Y' and statPoints == 0:
        print("No tienes ningun punto para gastar")
    mainMenu()
    return

