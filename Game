                    else:
                        playerHp -= enemyStrengh-defense
                        print(f"\n\nEl enemigo ataca! Hace {enemyStrengh-armor} de daño.")

                    if playerHp <= 0:
                        break

            action = input("\n\n 1. Golpear\n 2. Blockear\n 3. Escaparse\n\n\nElige una accion (1-3): ")


            if action == '1':

                if random.randint(1, 100) <= enemyDodge:
                    print("\n\nEl enemigo esquivo tu ataque!")
                else:
                    crit = random.randint(1, 100) <= perception
                    if Eblocking:
                        final_damage = (damage * (2 if crit else 1)) / 2
                        if crit:
                            print(f"\n\nEl enemigo bloquea tu ataque! Haces solo {final_damage} de daño (critico).")
                            if random.randint(1, 5) == 1:
                                statuses[random.randint(0,2)] += 3
                                print(f"\n\nEl enemigo es afectado por un efecto negativo!")
                        else:
                            print(f"\n\nEl enemigo bloquea tu ataque! Haces solo {final_damage} de daño.")
                        enemyHp -= final_damage
                    else:
                        final_damage = damage * (2 if crit else 1)
                        if crit:
                            print(f"\n\nGolpeas al enemigo! Critico — haces {final_damage} de daño.")
                            if random.randint(1, 5) == 1:
                                statuses[random.randint(0,2)] += 3
