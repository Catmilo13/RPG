        defeatStreak = 0
        xp += 50+maxEnemyHp/2
        coins += 20+enemyStrengh
        if xp >= xpToNextLevel:
            
            if savedShopSlot != 0:
                if randomizador <= 60:
                    shopSlots[0] = random.randint(1, 2)
                elif randomizador <= 90:
                    shopSlots[0] = 3
